{
  "annotations": { "list": [] },
  "description": "Isartor AI Gateway — Deflection, latency, cache, and cost-savings dashboard for performance tuning and SLO monitoring.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Deflection Rate (Overall)",
      "description": "Percentage of requests resolved before Layer 3 (cloud LLM). Higher is better — indicates cost savings.",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.3 },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.7 }
            ]
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "1 - (sum(increase(isartor_requests_total{final_layer=\"L3_Cloud\"}[$__range])) / sum(increase(isartor_requests_total[$__range])))",
          "legendFormat": "Deflection Rate",
          "instant": true
        }
      ]
    },
    {
      "id": 2,
      "title": "Request Distribution by Layer",
      "description": "Donut chart showing which layer resolved each request.",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "L0_AuthBlocked" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "L1a_ExactCache" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "L1b_SemanticCache" }, "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "L2_SLM" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "L3_Cloud" }, "properties": [{ "id": "color", "value": { "fixedColor": "purple", "mode": "fixed" } }] }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] },
        "pieType": "donut",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (final_layer) (increase(isartor_requests_total[$__range]))",
          "legendFormat": "{{final_layer}}",
          "instant": true
        }
      ]
    },
    {
      "id": 3,
      "title": "Tokens Saved (Cumulative)",
      "description": "Estimated cloud LLM tokens avoided by early resolution in L1a, L1b, or L2.",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "unit": "short"
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(isartor_tokens_saved_total[$__range]))",
          "legendFormat": "Tokens Saved",
          "instant": true
        }
      ]
    },
    {
      "id": 4,
      "title": "Est. Cost Savings ($0.01 / 1K tokens)",
      "description": "Rough dollar estimate of cloud LLM costs avoided.",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "unit": "currencyUSD",
          "decimals": 2
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(isartor_tokens_saved_total[$__range])) / 1000 * 0.01",
          "legendFormat": "Savings",
          "instant": true
        }
      ]
    },
    {
      "id": 5,
      "title": "Request Rate by Layer",
      "description": "Stacked time series showing requests per second, broken down by which layer resolved them.",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "stacking": { "mode": "normal", "group": "A" },
            "lineWidth": 1
          },
          "unit": "reqps"
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "mean"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (final_layer) (rate(isartor_requests_total[5m]))",
          "legendFormat": "{{final_layer}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Deflection Rate Over Time",
      "description": "Rolling deflection rate — percentage of requests NOT reaching L3 Cloud.",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "green", "mode": "fixed" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2,
            "pointSize": 5,
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.3 },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.7 }
            ]
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "1 - (sum(rate(isartor_requests_total{final_layer=\"L3_Cloud\"}[5m])) / sum(rate(isartor_requests_total[5m])))",
          "legendFormat": "Deflection Rate"
        }
      ]
    },
    {
      "id": 7,
      "title": "End-to-End Latency (P50 / P95 / P99)",
      "description": "Request latency percentiles across all layers.",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "pointSize": 3
          },
          "unit": "s"
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "P50",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, rate(isartor_request_duration_seconds_bucket[5m]))",
          "legendFormat": "P50"
        },
        {
          "refId": "P95",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, rate(isartor_request_duration_seconds_bucket[5m]))",
          "legendFormat": "P95"
        },
        {
          "refId": "P99",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, rate(isartor_request_duration_seconds_bucket[5m]))",
          "legendFormat": "P99"
        }
      ]
    },
    {
      "id": 8,
      "title": "Per-Layer Latency (P95)",
      "description": "P95 latency broken down by layer — identifies which layer is the bottleneck.",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "pointSize": 3
          },
          "unit": "s"
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum by (le, layer_name) (rate(isartor_layer_duration_seconds_bucket[5m])))",
          "legendFormat": "{{layer_name}}"
        }
      ]
    },
    {
      "id": 9,
      "title": "Tokens Saved by Layer Over Time",
      "description": "Rate of tokens saved, broken down by the layer that resolved the request.",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "stacking": { "mode": "normal", "group": "A" },
            "lineWidth": 1
          },
          "unit": "short"
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (final_layer) (rate(isartor_tokens_saved_total[5m]))",
          "legendFormat": "{{final_layer}}"
        }
      ]
    },
    {
      "id": 10,
      "title": "Cache Hit Rate (Exact vs. Semantic)",
      "description": "Percentage of total requests served by each cache layer.",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2,
            "pointSize": 3
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "lastNotNull"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "Exact",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(isartor_requests_total{final_layer=\"L1a_ExactCache\"}[5m])) / sum(rate(isartor_requests_total[5m]))",
          "legendFormat": "L1a Exact Cache"
        },
        {
          "refId": "Semantic",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(isartor_requests_total{final_layer=\"L1b_SemanticCache\"}[5m])) / sum(rate(isartor_requests_total[5m]))",
          "legendFormat": "L1b Semantic Cache"
        }
      ]
    },
    {
      "id": 11,
      "title": "Error Rate (5xx)",
      "description": "Percentage of requests returning 5xx errors. Should stay below SLO target.",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 38 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "red", "mode": "fixed" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 30,
            "lineWidth": 2,
            "pointSize": 3
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.005 },
              { "color": "red", "value": 0.01 }
            ]
          },
          "unit": "percentunit",
          "min": 0
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(isartor_requests_total{http_status=~\"5..\"}[5m])) / sum(rate(isartor_requests_total[5m]))",
          "legendFormat": "Error Rate"
        }
      ]
    },
    {
      "id": 12,
      "title": "SLM Resolution Rate",
      "description": "Percentage of requests resolved by the local SLM (Layer 2) without reaching the cloud.",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 38 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "fixedColor": "orange", "mode": "fixed" },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2,
            "pointSize": 3
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(isartor_requests_total{final_layer=\"L2_SLM\"}[5m])) / sum(rate(isartor_requests_total[5m]))",
          "legendFormat": "SLM Resolution Rate"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["isartor", "ai-gateway", "performance", "deflection", "cost-savings"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Isartor — Performance & Deflection Dashboard",
  "uid": "isartor-perf-deflection",
  "version": 1
}
