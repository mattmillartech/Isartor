{
  "annotations": {
    "list": []
  },
  "description": "Isartor AI Gateway — Per-layer request distribution, latency breakdown, and duration heatmap.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Request Distribution by Final Layer",
      "description": "Pie chart showing the proportion of requests handled by each gateway layer over the last hour.",
      "type": "piechart",
      "gridPos": { "h": 12, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "hideFrom": { "legend": false, "tooltip": false, "viz": false } }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "L0_AuthBlocked" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "L1a_ExactCache" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "L1b_SemanticCache" },
            "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "L2_SLM" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "L3_Cloud" },
            "properties": [{ "id": "color", "value": { "fixedColor": "purple", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] },
        "pieType": "donut",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (final_layer) (increase(isartor_requests_total[1h]))",
          "legendFormat": "{{final_layer}}",
          "instant": true
        }
      ]
    },
    {
      "id": 2,
      "title": "Layer Latency Breakdown (Avg Duration)",
      "description": "Bar gauge showing average span duration for each gateway processing layer, sourced from Tempo via TraceQL.",
      "type": "bargauge",
      "gridPos": { "h": 12, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "tempo", "uid": "tempo" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "continuous-GrYlRd" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red", "value": 0.5 }
            ]
          },
          "unit": "s",
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "minVizHeight": 10,
        "minVizWidth": 0,
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["mean"], "fields": "", "values": false },
        "showUnfilled": true,
        "valueMode": "color"
      },
      "targets": [
        {
          "refId": "exact",
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceql",
          "query": "{ name = \"layer1a_exact_lookup\" } | avg(duration)",
          "tableType": "spans"
        },
        {
          "refId": "semantic",
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceql",
          "query": "{ name = \"layer1b_semantic_process\" } | avg(duration)",
          "tableType": "spans"
        },
        {
          "refId": "slm",
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceql",
          "query": "{ name = \"layer2_slm_inference\" } | avg(duration)",
          "tableType": "spans"
        },
        {
          "refId": "llm",
          "datasource": { "type": "tempo", "uid": "tempo" },
          "queryType": "traceql",
          "query": "{ name = \"layer3_llm\" } | avg(duration)",
          "tableType": "spans"
        }
      ]
    },
    {
      "id": 3,
      "title": "Request Duration Heatmap by Final Layer",
      "description": "Heatmap of end-to-end request latency (isartor_request_duration_seconds) broken down by the final handling layer.",
      "type": "heatmap",
      "gridPos": { "h": 12, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "calculate": false,
        "cellGap": 1,
        "color": {
          "exponent": 0.5,
          "fill": "dark-orange",
          "mode": "scheme",
          "reverse": false,
          "scale": "exponential",
          "scheme": "Oranges",
          "steps": 64
        },
        "exemplars": { "color": "rgba(255, 0, 255, 0.7)" },
        "filterValues": { "le": 1e-9 },
        "legend": { "show": true },
        "rowsFrame": { "layout": "auto" },
        "showValue": "never",
        "tooltip": { "show": true, "yHistogram": true },
        "yAxis": {
          "axisPlacement": "left",
          "reverse": false,
          "unit": "s"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (le) (increase(isartor_request_duration_seconds_bucket{final_layer=~\".+\"}[5m]))",
          "legendFormat": "{{le}}",
          "format": "heatmap"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["isartor", "observability", "otel"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Isartor AI Gateway — Observability",
  "uid": "isartor-otel-dashboard",
  "version": 1
}