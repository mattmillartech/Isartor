# Isartor Gateway Environment Configuration

# ── General ────────────────────────────────────────────────────────
ISARTOR_HOST_PORT="0.0.0.0:8080"
ISARTOR_GATEWAY_API_KEY="changeme"

# ── Layer 1 (Semantic Cache) ───────────────────────────────────────
ISARTOR_CACHE_MODE="both"           # "exact", "semantic", or "both"
ISARTOR_EMBEDDING_MODEL="all-minilm"
ISARTOR_SIMILARITY_THRESHOLD="0.85"
ISARTOR_CACHE_TTL_SECS="300"
ISARTOR_CACHE_MAX_CAPACITY="10000"

# ── Layer 2 (Local SLM Triage) ─────────────────────────────────────
# Note: In docker-compose, "ollama:11434" resolves to the container
ISARTOR_LOCAL_SLM_URL="http://ollama:11434/api/generate"
ISARTOR_LOCAL_SLM_MODEL="llama3"

# ── Layer 3 (External LLM) ─────────────────────────────────────────
# "openai", "azure", "anthropic", or "xai"
ISARTOR_LLM_PROVIDER="openai"
ISARTOR_EXTERNAL_LLM_MODEL="gpt-4o-mini"
ISARTOR_EXTERNAL_LLM_API_KEY=""

# ── Provider-specific Setup ────────────────────────────────────────
# OpenAI
# ISARTOR_EXTERNAL_LLM_URL="https://api.openai.com/v1/chat/completions"

# Anthropic
# ISARTOR_EXTERNAL_LLM_URL="https://api.anthropic.com/v1/messages"
# ISARTOR_ANTHROPIC_VERSION="2023-06-01"

# xAI / Grok
# ISARTOR_EXTERNAL_LLM_URL="https://api.x.ai/v1/chat/completions"

# Azure OpenAI
# ISARTOR_EXTERNAL_LLM_URL="https://your-resource.openai.azure.com"
# ISARTOR_AZURE_DEPLOYMENT_ID="your-deployment-name"
# ISARTOR_AZURE_API_VERSION="2024-08-01-preview"

# ── Logging ────────────────────────────────────────────────────────
RUST_LOG="isartor=info"
