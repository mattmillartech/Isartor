# =============================================================================
# .env.sidecar — Level 2 environment overrides
#
# Copy this file and edit:
#   cp docker/.env.sidecar.example docker/.env.sidecar
#
# These values are picked up by docker-compose.sidecar.yml.
# Anything left empty or commented out falls back to the defaults
# baked into the compose file.
# =============================================================================

# ── Gateway Auth ───────────────────────────────────────────────────
ISARTOR_GATEWAY_API_KEY=changeme

# ── Layer 2 — Sidecar URLs ────────────────────────────────────────
# These point at the inference-sidecar service via Docker Compose DNS.
# You only need to change these if you rename the service or run
# the sidecar on a different host.
ISARTOR_LAYER2__SIDECAR_URL=http://inference-sidecar:8080
ISARTOR_LAYER2__MODEL_NAME=phi-3-mini
ISARTOR_LAYER2__TIMEOUT_SECONDS=30

# Legacy v1 endpoint (same sidecar, OpenAI-compatible path)
ISARTOR_LOCAL_SLM_URL=http://inference-sidecar:8080/v1/chat/completions
ISARTOR_LOCAL_SLM_MODEL=phi-3-mini

# ── Layer 3 — External LLM (optional cloud fallback) ──────────────
# Uncomment and fill in to enable Layer 3 cloud routing.
# ISARTOR_LLM_PROVIDER=openai
# ISARTOR_EXTERNAL_LLM_MODEL=gpt-4o-mini
# ISARTOR_EXTERNAL_LLM_API_KEY=sk-...
