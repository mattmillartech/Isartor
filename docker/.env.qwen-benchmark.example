# =============================================================================
# .env.qwen-benchmark — Qwen 2.5 Coder 7B benchmark environment overrides
#
# Copy this file and edit before starting the stack:
#   cp docker/.env.qwen-benchmark.example docker/.env.qwen-benchmark
#
# These values are picked up by docker-compose.qwen-benchmark.yml.
# Values set here take precedence over the defaults baked into the
# compose file.  Leave a value commented out to use the compose default.
#
# NOTE: The config crate uses separator("__"), so ALL Isartor env vars
#       require a double underscore after the ISARTOR prefix.
# =============================================================================

# ── Gateway auth ───────────────────────────────────────────────────
# Change this before running any benchmark that is exposed to a network.
ISARTOR__GATEWAY_API_KEY=changeme

# ── GPU acceleration (optional) ────────────────────────────────────
# Set to the number of transformer layers to offload to the GPU.
# For Qwen 2.5 Coder 7B: 33 layers total — use 33 for full GPU offload.
# Requires NVIDIA Container Toolkit and a GPU with ≥ 8 GB VRAM.
# Leave at 0 for CPU-only inference.
LLAMA_GPU_LAYERS=0

# ── Layer 3 fallback (optional cloud LLM) ──────────────────────────
# Requests that Layer 2 cannot deflect will reach Layer 3.
# Leave ISARTOR__EXTERNAL_LLM_API_KEY blank to disable Layer 3
# (undeflected requests will return a 502 error — acceptable for a
# pure Layer 2 smoke test).
#
# ISARTOR__LLM_PROVIDER=openai
# ISARTOR__EXTERNAL_LLM_MODEL=gpt-4o-mini
# ISARTOR__EXTERNAL_LLM_API_KEY=sk-...
# ISARTOR__EXTERNAL_LLM_URL=https://api.openai.com/v1/chat/completions

# Azure OpenAI (set ISARTOR__LLM_PROVIDER=azure to use)
# ISARTOR__AZURE_DEPLOYMENT_ID=gpt-4o-mini
# ISARTOR__AZURE_API_VERSION=2024-08-01-preview
